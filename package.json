{
  "name": "@sentry/warden",
  "version": "0.1.1",
  "description": "Event-driven agent that reacts to GitHub events and executes skills via Claude Code SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "warden": "dist/cli/index.js"
  },
  "scripts": {
    "cli": "tsx src/cli/index.ts",
    "build": "tsc",
    "build:action": "ncc build src/action/main.ts -o dist/action --source-map --license licenses.txt",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:examples": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks",
    "release": "pnpm lint && pnpm build && pnpm test && npm version"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm typecheck"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "docs/**/*.astro": [
      "pnpm -C docs build"
    ]
  },
  "keywords": [
    "github",
    "automation",
    "claude",
    "ai",
    "code-review",
    "security"
  ],
  "author": "Sentry",
  "license": "FSL-1.1-ALv2",
  "repository": "https://github.com/getsentry/warden",
  "bugs": {
    "url": "https://github.com/getsentry/warden/issues"
  },
  "homepage": "https://warden.sentry.dev",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.22",
    "@anthropic-ai/sdk": "^0.72.1",
    "@inquirer/select": "^5.0.4",
    "@octokit/rest": "^22.0.1",
    "chalk": "^5.6.2",
    "dotenv": "^17.2.3",
    "fast-glob": "^3.3.3",
    "figures": "^6.1.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "smol-toml": "^1.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.10",
    "@types/react": "^18.3.27",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.39.2",
    "ink-testing-library": "^4.0.0",
    "lint-staged": "^16.2.7",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
