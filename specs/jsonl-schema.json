{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://warden.dev/schemas/jsonl-v1.json",
  "title": "Warden JSONL Output",
  "description": "Schema for a single line in Warden's JSONL output. New run logs are homogeneous chunk records; legacy skill, summary, and fix-evaluation records remain parseable. Generated from src/cli/output/jsonl-schema-gen.ts — do not edit by hand.",
  "anyOf": [
    {
      "$ref": "#/$defs/ChunkRecord"
    },
    {
      "$ref": "#/$defs/SkillRecord"
    },
    {
      "$ref": "#/$defs/SummaryRecord"
    },
    {
      "$ref": "#/$defs/FixEvaluationRecord"
    }
  ],
  "$defs": {
    "ChunkRecord": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "number",
          "const": 1
        },
        "run": {
          "$ref": "#/$defs/RunMetadata"
        },
        "skill": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "chunk": {
          "type": "object",
          "properties": {
            "file": {
              "type": "string"
            },
            "index": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "total": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "lineRange": {
              "type": "string"
            }
          },
          "required": [
            "file",
            "index",
            "total",
            "lineRange"
          ],
          "additionalProperties": false
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "error",
            "skipped"
          ]
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Finding"
          }
        },
        "usage": {
          "$ref": "#/$defs/UsageStats"
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "auxiliaryUsage": {
          "$ref": "#/$defs/AuxiliaryUsage"
        },
        "error": {
          "$ref": "#/$defs/SkillError"
        },
        "skippedFiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SkippedFile"
          }
        }
      },
      "required": [
        "schemaVersion",
        "run",
        "skill",
        "chunk",
        "status",
        "findings",
        "durationMs"
      ],
      "additionalProperties": false
    },
    "RunMetadata": {
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "cwd": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "traceId": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "headSha": {
          "type": "string"
        }
      },
      "required": [
        "timestamp",
        "durationMs",
        "cwd",
        "runId"
      ],
      "additionalProperties": false
    },
    "Finding": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "verification": {
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/Location"
        },
        "additionalLocations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Location"
          }
        },
        "suggestedFix": {
          "$ref": "#/$defs/SuggestedFix"
        },
        "elapsedMs": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "id",
        "severity",
        "title",
        "description"
      ],
      "additionalProperties": false
    },
    "Location": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "startLine": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "endLine": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "path",
        "startLine"
      ],
      "additionalProperties": false
    },
    "SuggestedFix": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "diff": {
          "type": "string"
        }
      },
      "required": [
        "description",
        "diff"
      ],
      "additionalProperties": false
    },
    "UsageStats": {
      "type": "object",
      "properties": {
        "inputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "outputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cacheReadInputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cacheCreationInputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "costUSD": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "inputTokens",
        "outputTokens",
        "costUSD"
      ],
      "additionalProperties": false
    },
    "AuxiliaryUsage": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "$ref": "#/$defs/UsageStats"
      }
    },
    "SkillError": {
      "type": "object",
      "properties": {
        "code": {
          "$ref": "#/$defs/ErrorCode"
        },
        "message": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "additionalProperties": false
    },
    "ErrorCode": {
      "type": "string",
      "enum": [
        "auth_failed",
        "sdk_error",
        "subprocess_failure",
        "max_turns",
        "aborted",
        "all_hunks_failed",
        "skill_resolution_failed",
        "extraction_invalid_json",
        "extraction_unbalanced_json",
        "extraction_no_findings_json",
        "extraction_missing_findings_key",
        "extraction_findings_not_array",
        "extraction_llm_failed",
        "extraction_llm_timeout",
        "extraction_no_api_key",
        "unknown"
      ]
    },
    "SkippedFile": {
      "type": "object",
      "properties": {
        "filename": {
          "type": "string"
        },
        "reason": {
          "type": "string",
          "enum": [
            "pattern",
            "builtin"
          ]
        },
        "pattern": {
          "type": "string"
        }
      },
      "required": [
        "filename",
        "reason"
      ],
      "additionalProperties": false
    },
    "SkillRecord": {
      "type": "object",
      "properties": {
        "skill": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Finding"
          }
        },
        "metadata": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "usage": {
          "$ref": "#/$defs/UsageStats"
        },
        "skippedFiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SkippedFile"
          }
        },
        "failedHunks": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "failedExtractions": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "hunkFailures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/HunkFailure"
          }
        },
        "error": {
          "$ref": "#/$defs/SkillError"
        },
        "auxiliaryUsage": {
          "$ref": "#/$defs/AuxiliaryUsage"
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FileRecord"
          }
        },
        "model": {
          "type": "string"
        },
        "run": {
          "$ref": "#/$defs/RunMetadata"
        }
      },
      "required": [
        "skill",
        "summary",
        "findings",
        "run"
      ],
      "additionalProperties": false
    },
    "HunkFailure": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "analysis",
            "extraction"
          ]
        },
        "filename": {
          "type": "string"
        },
        "lineRange": {
          "type": "string"
        },
        "code": {
          "$ref": "#/$defs/ErrorCode"
        },
        "message": {
          "type": "string"
        },
        "preview": {
          "type": "string"
        },
        "attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "type",
        "filename",
        "lineRange",
        "code",
        "message"
      ],
      "additionalProperties": false
    },
    "FileRecord": {
      "type": "object",
      "properties": {
        "filename": {
          "type": "string"
        },
        "findings": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "usage": {
          "$ref": "#/$defs/UsageStats"
        }
      },
      "required": [
        "filename",
        "findings"
      ],
      "additionalProperties": false
    },
    "SummaryRecord": {
      "type": "object",
      "properties": {
        "run": {
          "$ref": "#/$defs/RunMetadata"
        },
        "type": {
          "type": "string",
          "const": "summary"
        },
        "totalFindings": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "bySeverity": {
          "type": "object",
          "properties": {
            "high": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "medium": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "low": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "high",
            "medium",
            "low"
          ],
          "additionalProperties": false
        },
        "usage": {
          "$ref": "#/$defs/UsageStats"
        },
        "totalSkippedFiles": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "auxiliaryUsage": {
          "$ref": "#/$defs/AuxiliaryUsage"
        },
        "failedSkills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "totalFailedHunks": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "totalFailedExtractions": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "error": {
          "$ref": "#/$defs/SkillError"
        }
      },
      "required": [
        "run",
        "type",
        "totalFindings",
        "bySeverity"
      ],
      "additionalProperties": false
    },
    "FixEvaluationRecord": {
      "type": "object",
      "properties": {
        "run": {
          "$ref": "#/$defs/RunMetadata"
        },
        "type": {
          "type": "string",
          "const": "fix-evaluation"
        },
        "evaluated": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "resolved": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "needsAttention": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "skipped": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "failedEvaluations": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "usage": {
          "$ref": "#/$defs/UsageStats"
        },
        "evaluations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FixEvalDetail"
          }
        }
      },
      "required": [
        "run",
        "type",
        "evaluated",
        "resolved",
        "needsAttention",
        "skipped",
        "failedEvaluations"
      ],
      "additionalProperties": false
    },
    "FixEvalDetail": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "findingId": {
          "type": "string"
        },
        "verdict": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "not_attempted",
                "attempted_failed",
                "resolved"
              ]
            },
            {
              "type": "string",
              "const": "re_detected"
            }
          ]
        },
        "reasoning": {
          "type": "string"
        },
        "durationMs": {
          "type": "number",
          "minimum": 0
        },
        "usage": {
          "$ref": "#/$defs/UsageStats"
        }
      },
      "required": [
        "path",
        "line",
        "verdict",
        "durationMs",
        "usage"
      ],
      "additionalProperties": false
    }
  }
}
